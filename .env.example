# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs. Only these IDs can
# message the bot — every other sender is silently ignored. Get yours
# from @userinfobot.
TELEGRAM_ALLOWED_USER_IDS=

# Anthropic API key from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Directory the agent operates inside. Repos cloned under this path are
# what the agent can read/edit/commit. Default = ./repos relative to bot
# directory.
WORKING_ROOT=./repos

# Where to persist conversation state (per Telegram chat).
DATA_DIR=./data

# Model. Defaults to claude-sonnet-4-7 (best for code). Use
# claude-opus-4-7 for deeper reasoning at higher cost.
CLAUDE_MODEL=claude-sonnet-4-7
