{
  "name": "relay-bot",
  "version": "0.1.0",
  "description": "Telegram bridge for Claude Agent SDK — text the agent from your phone, it does the work.",
  "private": true,
  "type": "module",
  "main": "src/bot.ts",
  "scripts": {
    "start": "tsx src/bot.ts",
    "dev": "tsx --watch src/bot.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
